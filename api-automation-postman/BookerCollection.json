    {
      "name": "Get All Bookings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 3000ms\", function () {",
              "    var response_time = pm.response.responseTime;",
              "    pm.expect(response_time).to.be.below(3000);",
              "});",
              "",
              "pm.test(\"Response body contains created bookingid {{booking_id}}\", function () {",
              "    var responseJson = pm.response.json();",
              "    var bookingId = parseInt(pm.environment.get(\"booking_id\"));",
              "    var found = false;",
              "    for (var i = 0; i < responseJson.length; i++) {",
              "        if (responseJson[i].bookingid === bookingId) {",
              "            found = true;",
              "            break;",
              "        }",
              "    }",
              "    pm.expect(found).to.be.true;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
