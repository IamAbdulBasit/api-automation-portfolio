    {
      "name": "Create Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 2000ms\", function () {",
              "    var response_time = pm.response.responseTime;",
              "    pm.expect(response_time).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Token is not undefined/null/empty\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.token).to.not.be.undefined;",
              "    pm.expect(jsonData.token).to.not.null;",
              "    pm.expect(jsonData.token).to.not.empty;",
              "    pm.expect(jsonData.token).to.be.a('string');",
              "});",
              "",
              "// .exist (covers both null AND undefined)",
              "pm.test(\"Token exists/present in response body\", function (){",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.token).to.exist;",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"token\", jsonData.token);",
              "console.log(\"The token is:\", jsonData.token);",
              "console.log(\"The token type is:\", jsonData.token_type);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
