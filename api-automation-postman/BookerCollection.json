        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Check if the booking was updated successfully\", function () {\r",
              "    pm.expect(pm.response.json().firstname).to.eql(\"Jim Partial Update\");\r",
              "    pm.expect(pm.response.json().lastname).to.eql(\"Brown Update\");\r",
              "    pm.expect(pm.response.json().totalprice).to.eql(500);\r",
              "    pm.expect(pm.response.json().depositpaid).to.eql(false);\r",
              "    pm.expect(pm.response.json().bookingdates.checkin).to.eql(\"2022-01-01\");\r",
              "    pm.expect(pm.response.json().bookingdates.checkout).to.eql(\"2022-12-12\");\r",
              "    pm.expect(pm.response.json().additionalneeds).to.eql(\"Lunch\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check if the response status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
